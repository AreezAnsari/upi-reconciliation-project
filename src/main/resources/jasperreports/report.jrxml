<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports 
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="EmployeeReport"
              pageWidth="595"
              pageHeight="842"
              columnWidth="540"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <!-- Define Styles without backgroundColor -->
    <style name="titleStyle" fontName="Arial" fontSize="14" isBold="true"/>
    <style name="headerStyle" fontName="Arial" fontSize="12" isBold="true"/>
    <style name="columnStyle" fontName="Arial" fontSize="10"/>
    <style name="dataStyle" fontName="Arial" fontSize="10"/>
    
    <!-- Define fields that correspond to the JasperReportDto -->
    <field name="id" class="java.lang.Long"/>
    <field name="name" class="java.lang.String"/>
    <field name="age" class="java.lang.Long"/>
    <field name="processId" class="java.lang.Long"/>

    <!-- Report Header -->
    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="595" height="50"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[EXTRACTION REPORT]]></text>
            </staticText>
        </band>
    </title>

    <!-- Column Header -->
    <columnHeader>
        <band height="30">
            <staticText>
                <reportElement x="0" y="0" width="100" height="30" style="headerStyle"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="0" width="100" height="30" style="headerStyle" />
                <textElement textAlignment="Center"/>
                <text><![CDATA[Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="0" width="100" height="30" style="headerStyle" />
                <textElement textAlignment="Center"/>
                <text><![CDATA[Age]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="0" width="100" height="30" style="headerStyle" />
                <textElement textAlignment="Center"/>
                <text><![CDATA[Process ID]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Detail Section -->
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="100" height="20" style="dataStyle"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="100" y="0" width="100" height="20" style="dataStyle"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="200" y="0" width="100" height="20" style="dataStyle"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{age}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="300" y="0" width="100" height="20" style="dataStyle"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{processId}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
