<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports 
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Extraction Report"
              pageWidth="595"
              pageHeight="842"
              columnWidth="540"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">
              
    <!-- Define Styles -->
   <style name="titleStyle" fontName="Arial" fontSize="14" isBold="true"/>
    <style name="headerStyle" fontName="Arial" fontSize="12" isBold="true"/>
    <style name="columnStyle" fontName="Arial" fontSize="10"/>
    <style name="dataStyle" fontName="Arial" fontSize="10"/>

    <!-- Define Parameters -->
    <parameter name="reportTitle" class="java.lang.String"/>

    <!-- Define Fields -->
    <field name="fileName" class="java.lang.String"/>
    <field name="fileDate" class="java.lang.String"/>
    <field name="extractionDate" class="java.lang.String"/>
    <field name="totalCount" class="java.lang.String"/>
    <field name="totalAmount" class="java.math.BigDecimal"/>
	
   <!-- Title Band -->
   <pageHeader>
    <band height="50">
        <textField>
            <reportElement x="60" y="10" width="200" height="30"/>
            <textFieldExpression><![CDATA[$P{reportTitle}]]></textFieldExpression>
        </textField>
         <line>
             <reportElement x="0" y="45" width="540" height="1" />
         </line>
    </band>
   </pageHeader>

    <!-- Detail Band -->
    <detail>
        <band height="120">
            <textField>
                <reportElement x="0" y="0" width="540" height="20" />
                <textFieldExpression><![CDATA["File Name : " +$F{fileName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="25" width="540" height="20" />
                <textFieldExpression><![CDATA["File Date : " +$F{fileDate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="50" width="540" height="20" />
                <textFieldExpression><![CDATA["Extraction Date : " +$F{extractionDate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="75" width="540" height="20" />
                <textFieldExpression><![CDATA["Total Count (TXN) : " +$F{totalCount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="100" width="540" height="20" />
                <textFieldExpression><![CDATA["Total Amount (TXN) : " +$F{totalAmount}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
